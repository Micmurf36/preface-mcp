# ── LLM Provider ──────────────────────────────────────────────────────────────
# Used by extract_rules to analyze transcripts.
# Options: claude | openai | ollama
BRIEF_LLM_PROVIDER=claude

# API key for the selected provider.
# Not needed if using ollama (runs locally).
BRIEF_API_KEY=your-api-key-here

# Optional: override the default model for your provider.
# claude default : claude-haiku-4-5-20251001
# openai default : gpt-4o-mini
# ollama default : llama3
BRIEF_LLM_MODEL=

# ── Ollama (only needed if BRIEF_LLM_PROVIDER=ollama) ─────────────────────────
BRIEF_OLLAMA_URL=http://localhost:11434

# ── Server ────────────────────────────────────────────────────────────────────
# Port Brief listens on (default: 8080)
BRIEF_PORT=8080

# Token budget for get_brief output (default: 600).
# 600 tokens ≈ 30–40 concise rules. Raise it if you have a lot of rules;
# lower it if you want an even lighter context footprint.
BRIEF_TOKEN_BUDGET=600

# Path to the SQLite database file.
# In Docker, keep this under /data so it's stored in the named volume.
BRIEF_DB_PATH=/data/brief.db
